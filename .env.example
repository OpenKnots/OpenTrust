# OpenTrust auth mode.
# - token: require OPENTRUST_AUTH_TOKEN
# - password: require OPENTRUST_AUTH_PASSWORD
# - none: disable auth entirely (not recommended outside isolated localhost use)
OPENTRUST_AUTH_MODE=token

# Shared credential for token mode.
OPENTRUST_AUTH_TOKEN=

# Shared credential for password mode.
OPENTRUST_AUTH_PASSWORD=

# Allow auth bypass when accessed via localhost / 127.0.0.1 / ::1.
# Set to false for strict auth everywhere.
OPENTRUST_ALLOW_LOCALHOST_BYPASS=true

# Canonical app URL used for metadata / OG resolution.
OPENTRUST_APP_URL=http://localhost:3000

# Optional override for the sqlite-vec extension path used by semantic indexing.
# Leave this unset unless auto-detection does not work in your local environment.
OPENTRUST_SQLITE_VEC_PATH=

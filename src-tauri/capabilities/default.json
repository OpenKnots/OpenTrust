{
  "$schema": "https://raw.githubusercontent.com/niceclaw/tauri-v2/main/crates/tauri-utils/schema.json",
  "identifier": "default",
  "description": "Default capability set for OpenTrust desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "process:default",
    "notification:default",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "notification:allow-notify"
  ]
}

  "devDependencies": {
    "@secretlint/core": "^11.4.0",
    "@secretlint/secretlint-rule-preset-recommend": "^11.4.0",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "secretlint": "^11.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
